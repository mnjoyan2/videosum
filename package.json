{
  "name": "videosum",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Transcribe videos with timestamps, summarize them with OpenAI, and stitch a shorter highlight video with ffmpeg.",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "start": "node src/index.mjs",
    "ui": "npm run build && node src/server.mjs",
    "ui:server": "node src/server.mjs",
    "check": "node --check src/index.mjs && node --check src/pipeline.mjs && node --check src/server.mjs && tsc --noEmit -p tsconfig.json && vite build --config vite.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
